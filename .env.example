# ── DeepSeek ────────────────────────────────────────────────
# Get your key at https://platform.deepseek.com/
# Copy this file to .env.local and fill in real values.
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Security ─────────────────────────────────────────────────
# Optional: set a random string to protect your API routes from
# unauthorized use. Must match VITE_SOHO_API_SECRET below.
# Leave blank to allow all requests (personal / local dev default).
SOHO_API_SECRET=

# Restrict CORS to your production domain, e.g. https://myapp.vercel.app
# Leave blank to allow all origins (fine for personal deployments).
ALLOWED_ORIGIN=

# ── Client-side (must start with VITE_) ─────────────────────
# Must match SOHO_API_SECRET above so the browser can authenticate.
VITE_SOHO_API_SECRET=
